rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // ===============================================================
    // Assumed Data Model
    // ===============================================================
    //
    // Collection: users
    // Document ID: uid
    // Fields:
    //   - uid: string
    //   - email: string
    //   - name: string
    //   - role: string (CEO, COO, Head of Science)
    //
    // Collection: projects
    // Document ID: auto
    // Fields:
    //   - title: string
    //   - status: string
    //   - createdBy: string (CEO UID)
    //   - createdAt: timestamp
    //
    // Collection: tasks
    // Document ID: auto
    // Fields:
    //   - assignedTo: string (UID)
    //   - status: string
    //   - deadline: timestamp
    //
    // ===============================================================

    // ===============================================================
    // Helper Functions
    // ===============================================================
    function isAuthenticated() {
      return request.auth != null;
    }

    function getUserData() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
    }

    function isCEO() {
      return isAuthenticated() && getUserData().role == 'CEO';
    }

    function isManager() {
      return isAuthenticated() && (getUserData().role == 'CEO' || getUserData().role == 'COO');
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    function hasOnlyAllowedFields(fields) {
      return request.resource.data.keys().hasOnly(fields);
    }

    function isValidProject(data) {
      return data.title is string && data.title.size() > 0 && data.title.size() < 200 &&
             data.status in ['Backlog', 'In Progress', 'Review', 'Completed'];
    }

    function isValidTask(data) {
      return data.title is string && data.title.size() > 0 && data.title.size() < 200 &&
             data.status in ['Pending', 'In Progress', 'Done'];
    }

    // ===============================================================
    // Rules
    // ===============================================================

    match /users/{userId} {
      allow read: if isAuthenticated();
      // Allow creation if the user is setting their own profile (bootstrap)
      allow create: if isOwner(userId) && request.resource.data.email == request.auth.token.email;
      allow update: if isOwner(userId) && request.resource.data.role == resource.data.role;
    }

    match /projects/{projectId} {
      allow read: if isAuthenticated();
      allow create: if isCEO() && isValidProject(request.resource.data);
      allow update: if isCEO() && isValidProject(request.resource.data);
      allow delete: if isCEO();
    }

    match /tasks/{taskId} {
      allow read: if isAuthenticated();
      allow create: if isManager();
      allow update: if isAuthenticated() && (isManager() || request.auth.uid == resource.data.assignedTo);
      allow delete: if isManager();
    }

    match /leave_requests/{requestId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated() && request.resource.data.employeeId == request.auth.uid;
      allow update: if isManager() || (isAuthenticated() && request.resource.data.employeeId == request.auth.uid && resource.data.status == 'Pending');
    }

    match /accounting/{recordId} {
      allow read: if isManager();
      allow create: if isAuthenticated();
      allow update: if isManager();
    }

    match /assets/{assetId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated() && 
        request.resource.data.uploadedBy == request.auth.uid &&
        request.resource.data.name is string &&
        request.resource.data.url is string;
      allow delete: if isAuthenticated() && (request.auth.uid == resource.data.uploadedBy || isCEO());
    }

    match /test/connection {
      allow read: if true;
    }
  }
}
